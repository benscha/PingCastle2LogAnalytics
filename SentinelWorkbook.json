		{
			"type": 3,
			"content": {
				"version": "KqlItem/1.0",
				"query": "PingCastle_Findings_CL\n| summarize arg_max(TimeGenerated, *) by DomainFQDN, RiskId\n| summarize Count = count() by Severity, Category\n| order by Count desc",
				"size": 0,
				"title": "Findings by Severity and Category",
				"timeContextFromParameter": "TimeRange",
				"queryType": 0,
				"resourceType": "microsoft.operationalinsights/workspaces",
				"visualization": "barchart",
				"chartSettings": {
					"xAxis": "Category",
					"yAxis": [
						"Count"
					],
					"splitBy": "Severity",
					"seriesLabelSettings": [
