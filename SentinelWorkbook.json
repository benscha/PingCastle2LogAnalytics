		{
			"type": 1,
			"content": {
				"json": "# 🛡️ Active Directory Security — PingCastle Dashboard\n\nScores range from **0** (best) to **100** (worst). The Global Risk Score equals the maximum of the four category scores.\n\n---"
			},
			"name": "title"
		},
		{
			"type": 1,
			"content": {
				"json": "## 🌐 Overall Average Domain Risk Score\n_Average across all domains — based on the latest scan per domain._"
			},
			"name": "section-header-overall"
		},
		{
			"type": 3,
			"content": {
				"version": "KqlItem/1.0",
				"query": "union\n	(PingCastle_Summary_CL | summarize arg_max(TimeGenerated, *) by DomainFQDN | summarize v = round(avg(GlobalScore), 0)					| project Name = 'Avg Risk Score',		Value = toint(v)),\n	(PingCastle_Summary_CL | summarize arg_max(TimeGenerated, *) by DomainFQDN | summarize v = dcount(DomainFQDN)									| project Name = 'Domains Scanned',	 Value = toint(v)),\n	(PingCastle_Summary_CL | summarize arg_max(TimeGenerated, *) by DomainFQDN | summarize v = sum(FindingsCount_Critical)					 | project Name = 'Critical Findings', Value = toint(v)),\n	(PingCastle_Summary_CL | summarize arg_max(TimeGenerated, *) by DomainFQDN | summarize v = sum(FindingsCount_High)							 | project Name = 'High Findings',		 Value = toint(v)),\n	(PingCastle_Summary_CL | summarize arg_max(TimeGenerated, *) by DomainFQDN | summarize v = sum(FindingsCount_Medium)						 | project Name = 'Medium Findings',	 Value = toint(v)),\n	(PingCastle_Summary_CL | summarize arg_max(TimeGenerated, *) by DomainFQDN | summarize v = sum(FindingsCount_Low)								| project Name = 'Low Findings',			Value = toint(v))",
				"size": 4,
				"title": "KPIs — Latest Scan per Domain (all time)",
				"timeContext": {
					"durationMs": 31536000000
				},
				"queryType": 0,
				"resourceType": "microsoft.operationalinsights/workspaces",
				"visualization": "tiles",
				"tileSettings": {
					"showBorder": true,
					"titleContent": {
						"columnMatch": "Name",
						"formatter": 1
					},
					"leftContent": {
						"columnMatch": "Value",
						"formatter": 4,
						"numberFormat": {
							"unit": 0,
							"options": {
								"style": "decimal",
								"maximumFractionDigits": 0
							}
						}
					}
				}
			},
			"customWidth": "100",
			"name": "kpi-tiles"
		},
		{
			"type": 3,
			"content": {
				"version": "KqlItem/1.0",
				"query": "PingCastle_Summary_CL\n| summarize arg_max(TimeGenerated, *) by DomainFQDN\n| project\n		Domain							 = DomainFQDN,\n		['Global Score']		 = GlobalScore,\n		['Stale Objects']		= StaleObjectsScore,\n		['Priv. Accounts']	 = PrivilegiedGroupScore,\n		Trusts							 = TrustScore,\n		Anomalies						= AnomalyScore,\n		['Maturity Level']	 = MaturityLevel,\n		Critical						 = FindingsCount_Critical,\n		High								 = FindingsCount_High,\n		Medium							 = FindingsCount_Medium,\n		Low									= FindingsCount_Low,\n		['Last Scan']				= TimeGenerated\n| order by ['Global Score'] desc",
				"size": 4,
				"title": "Domain Score Overview",
