		},
		{
			"type": 3,
			"content": {
				"version": "KqlItem/1.0",
				"query": "PingCastle_Findings_CL\n| summarize arg_max(TimeGenerated, *) by DomainFQDN, RiskId\n| project\n		Domain		= DomainFQDN,\n		Severity	= Severity,\n		Points		= Points,\n		Category	= Category,\n		RiskId		= RiskId,\n		Rationale = Rationale,\n		ScanDate	= TimeGenerated\n| order by Points desc, Domain asc",
				"size": 3,
				"title": "All Active Findings",
				"timeContextFromParameter": "TimeRange",
				"queryType": 0,
				"resourceType": "microsoft.operationalinsights/workspaces",
				"visualization": "table",
				"gridSettings": {
					"formatters": [
						{
