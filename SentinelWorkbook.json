		{
			"type": 1,
			"content": {
				"json": "---\n## 📈 Score Trends — Last 52 Weeks\n_Weekly aggregation · max 52 data points per domain · each line = one domain_"
			},
			"name": "section-header-trends"
		},
		{
			"type": 3,
			"content": {
				"version": "KqlItem/1.0",
				"query": "PingCastle_Summary_CL\n| where TimeGenerated > ago(364d)\n| summarize GlobalScore = round(avg(GlobalScore), 1) by bin(TimeGenerated, 7d), DomainFQDN\n| union (\n		PingCastle_Summary_CL\n		| where TimeGenerated > ago(364d)\n		| summarize GlobalScore = round(avg(GlobalScore), 1) by bin(TimeGenerated, 7d)\n		| extend DomainFQDN = '~~~ Avg all domains ~~~'\n)\n| order by DomainFQDN asc, TimeGenerated asc",
				"size": 0,
				"title": "Global Risk Score Trend",
				"timeContext": {
					"durationMs": 31536000000
				},
				"queryType": 0,
				"resourceType": "microsoft.operationalinsights/workspaces",
				"visualization": "linechart",
				"chartSettings": {
					"xAxis": "TimeGenerated",
					"yAxis": [
						"GlobalScore"
					],
					"splitBy": "DomainFQDN",
					"ySettings": {
						"min": 0,
						"max": 100
					}
				}
			},
			"customWidth": "100",
			"name": "trend-global"
		},
		{
			"type": 3,
			"content": {
				"version": "KqlItem/1.0",
				"query": "PingCastle_Summary_CL\n| where TimeGenerated > ago(364d)\n| summarize\n		['Stale Objects']	= round(avg(StaleObjectsScore), 1),\n		['Priv. Accounts'] = round(avg(PrivilegiedGroupScore), 1),\n		Trusts						 = round(avg(TrustScore), 1),\n		Anomalies					= round(avg(AnomalyScore), 1)\n		by bin(TimeGenerated, 7d)\n| order by TimeGenerated asc",
				"size": 0,
				"title": "Category Score Trends — Avg across all domains",
				"timeContext": {
					"durationMs": 31536000000
				},
				"queryType": 0,
				"resourceType": "microsoft.operationalinsights/workspaces",
				"visualization": "linechart",
				"chartSettings": {
					"xAxis": "TimeGenerated",
					"yAxis": [
						"Stale Objects",
						"Priv. Accounts",
						"Trusts",
						"Anomalies"
					],
					"ySettings": {
						"min": 0,
						"max": 100
					}
				}
			},
			"customWidth": "100",
			"name": "trend-categories"
		},
		{
			"type": 1,
			"content": {
				"json": "---\n## 🔍 Active Findings — Latest Scan\n_Only findings with Points > 0, based on the most recent scan per domain._"
			},
			"name": "section-header-findings"
		},
		{
			"type": 3,
			"content": {
				"version": "KqlItem/1.0",
				"query": "PingCastle_Findings_CL\n| summarize arg_max(TimeGenerated, *) by DomainFQDN, RiskId\n| summarize\n		Critical = countif(Severity == 'Critical'),\n		High		 = countif(Severity == 'High'),\n		Medium	 = countif(Severity == 'Medium'),\n		Low			= countif(Severity == 'Low')\n		by Domain = DomainFQDN\n| order by Critical desc, High desc",
				"size": 4,
				"title": "Findings Summary by Domain",
				"timeContextFromParameter": "TimeRange",
				"queryType": 0,
				"resourceType": "microsoft.operationalinsights/workspaces",
				"visualization": "table",
				"gridSettings": {
					"formatters": [
						{
							"columnMatch": "Critical",
							"formatter": 18,
							"formatOptions": {
								"thresholdsOptions": "colors",
								"thresholdsGrid": [
									{
										"operator": "Default",
										"thresholdValue": null,
										"representation": "green",
